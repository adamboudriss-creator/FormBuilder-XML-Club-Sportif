<?xml version="1.0" encoding="UTF-8"?>

<formulaire xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            xsi:noNamespaceSchemaLocation="inscription.xsd">
    
    <titre>Inscription Club Sportif</titre>
    
    <input
        name="nom"
        label="Nom"
        type="text"
        required="true"
        minlength="3"/>
    
    <input
        name="prenom"
        label="Prénom"
        type="text"
        required="true"
        minlength="3"/>
    
    <input
        name="email"
        label="Email"
        type="email"
        required="true"/>
    
    <input
        name="telephone"
        label="Téléphone"
        type="text"
        required="true"
        pattern="[0-9]{10}"/>
    
    <input
        name="age"
        label="Âge"
        type="number"
        required="true"/>
    
    <select
        name="sport"
        label="Sport">
        
        <option>Football</option>
        <option>Basketball</option>
        <option>Natation</option>
        <option>Tennis</option>
        
    </select>
    
    <select
        name="niveau"
        label="Niveau">
        
        <option>Débutant</option>
        <option>Intermédiaire</option>
        <option>Avancé</option>
        
    </select>
    
    <textarea
        name="adresse"
        label="Adresse"
        required="true"/>
    
    <checkbox
        name="certificat"
        label="Certificat médical fourni"/>
    
    <checkbox
        name="conditions"
        label="J'accepte les conditions d'utilisation"/>
    
</formulaire>