<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="inscription.xslt"?>

<formulaire xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            xsi:noNamespaceSchemaLocation="inscription.xsd">

    <titre>Inscription Club Sportif</titre>

    <input
        name="nom"
        label="Nom"
        type="text"
        required="true"
        minlength="3"/>

    <input
        name="prenom"
        label="Prenom"
        type="text"
        required="true"
        minlength="3"/>

    <input
        name="email"
        label="Email"
        type="email"
        required="true"/>

    <input
        name="telephone"
        label="Telephone"
        type="text"
        required="true"
        pattern="[0-9]{10}"/>

    <input
        name="age"
        label="Age"
        type="number"
        required="true"/>

    <select
        name="sport"
        label="Sport">

        <option>Football</option>
        <option>Basketball</option>
        <option>Natation</option>
        <option>Tennis</option>

    </select>

    <select
        name="niveau"
        label="Niveau">

        <option>Debutant</option>
        <option>Intermediaire</option>
        <option>Avance</option>


                
    </select>

            
    <textarea
        name="adresse"
        label="Adresse"
        required="true"></textarea>

    <checkbox
        name="certificat"
        label="Certificat medical fourni"/>

    <checkbox
        name="conditions"
        label="J'accepte les  conditions"/>

</formulaire>
